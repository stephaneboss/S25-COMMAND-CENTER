# S25 LUMIÈRE — Configuration
# Copier vers .env et remplir les valeurs

# ─── Home Assistant ───────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=votre_long_lived_token_ici

# ─── AI APIs ──────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
KIMI_API_KEY=

# ─── Trading ──────────────────────────────────────
MEXC_API_KEY=
MEXC_SECRET_KEY=

# ─── Akash ────────────────────────────────────────
AKASH_ENDPOINT=http://localhost:5050
AKASH_WALLET_ADDRESS=
AKASH_COCKPIT_ORIGIN=
AKASH_COCKPIT_HOST=
TREASURY_DEPLOYMENTS=

# ─── Cockpit ──────────────────────────────────────
PORT=7777
COCKPIT_URL=https://s25.smajor.org
SECRET_KEY=change_me_x100

# ─── Watchdog ─────────────────────────────────────
CHECK_INTERVAL=60
MAX_RETRIES=3
TUNNEL_SCRIPT=/config/scripts/start_s25_tunnel.sh

# Portable runtime contract
MEMORY_DIR=/app/memory
S25_SHARED_SECRET=change_me_s25_secret
COCKPIT_URL=http://localhost:7777
RUN_ORACLE_AGENT=true
RUN_ONCHAIN_GUARDIAN=true
ORACLE_POLL_SECONDS=300
ORACLE_SYMBOLS=BTC,ETH,AKT,ATOM
ONCHAIN_POLL_SECONDS=420
ONCHAIN_TOKEN_LIST=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ─── Wallet ──────────────────────────────────────
WALLET_MNEMONIC=
AKASH_WALLET_ADDRESS=
S25_WEBHOOK_PRIVATE_KEY=
